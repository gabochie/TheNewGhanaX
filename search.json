---
layout: null
---
[
  {% for trap in site.traps %}
  {
    "title": {{ trap.title | jsonify }},
    "url": {{ trap.url | relative_url | jsonify }},
    "tagline": {{ trap.tagline | jsonify }},
    "keywords": {{ trap.keywords | jsonify }},
    "takeaways": {{ trap.takeaways | jsonify }},
    "content": {{ trap.content | strip_html | strip_newlines | truncate: 500 | jsonify }},
    "number": {{ trap.number }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
